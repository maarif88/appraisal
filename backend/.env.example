# ─────────────────────────────────────────────────
# YPYM Appraisal - Backend Environment Variables
# ─────────────────────────────────────────────────

# Server
PORT=3100
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (SQLite - file path relative to backend/)
DATABASE_PATH=./data/ypym-appraisal.db

# Google Ads API (required for production, mock mode if empty)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# DataForSEO (required for production, mock mode if empty)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Exchange Rate (optional - open.er-api.com is free without key)
FX_RATE_API_KEY=

# Defaults
DEFAULT_CURRENCY_BASE=USD
DEFAULT_LOCALE_COUNTRY=ID
DEFAULT_LOCALE_LANGUAGE=id

# Pipeline limits
MAX_KEYWORDS_PER_RUN=500
AUTOCOMPLETE_DELAY_MIN_MS=300
AUTOCOMPLETE_DELAY_MAX_MS=800
